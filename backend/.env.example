# ============================================================
# KavachNidhi Backend — Environment Variables
# Copy this file to .env and fill in values
# Never commit .env to git
# ============================================================

# Supabase (shared across all team members)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=kyc-documents

# Razorpay (managed by Keshav)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# OpenWeatherMap (managed by Keshav — share with Adwaith)
OPENWEATHERMAP_API_KEY=

# TomTom Traffic (managed by Keshav — share with Adwaith)
TOMTOM_API_KEY=

# Mock flags (set to true if API key not available yet)
USE_MOCK_PAYMENTS=false
USE_MOCK_WEATHER=false
USE_MOCK_TRAFFIC=false

# KavachBrain engine
KAVACHBRAIN_INTERVAL_SECONDS=60
